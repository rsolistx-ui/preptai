<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PREPT AI Live — Real-Time Interview Coach</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;background:#07070e;color:#edeaf7;font-family:'Outfit',sans-serif;font-size:15px;line-height:1.6;overflow-x:hidden}
body::before{content:'';position:fixed;top:-20%;left:10%;width:600px;height:500px;background:radial-gradient(ellipse,rgba(123,109,244,0.06) 0%,transparent 65%);pointer-events:none;z-index:0}

/* NAV */
nav{position:sticky;top:0;z-index:100;display:flex;align-items:center;padding:0 24px;height:58px;border-bottom:1px solid rgba(255,255,255,0.06);background:rgba(7,7,14,0.95);backdrop-filter:blur(20px);gap:12px}
.nav-logo{font-family:'Outfit',sans-serif;font-size:17px;font-weight:800;color:#e6c668;text-decoration:none;letter-spacing:-0.3px;margin-right:auto}
.nav-badge{padding:3px 10px;border-radius:12px;background:rgba(123,109,244,0.12);border:1px solid rgba(123,109,244,0.25);font-size:11px;font-weight:700;color:#a498ff;display:flex;align-items:center;gap:5px}
.nav-badge-dot{width:6px;height:6px;border-radius:50%;background:#ef5f5f;animation:pulse 1.2s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.4;transform:scale(0.7)}}
.nav-btn{padding:6px 16px;border-radius:8px;font-family:'Outfit',sans-serif;font-size:13px;font-weight:600;cursor:pointer;text-decoration:none;transition:all 0.2s}
.nav-btn-ghost{background:transparent;border:1px solid rgba(255,255,255,0.09);color:#8c89a6}
.nav-btn-ghost:hover{border-color:rgba(255,255,255,0.16);color:#edeaf7}
.nav-btn-gold{background:#e6c668;border:none;color:#07070e}
.nav-btn-gold:hover{background:#f5dfa0}

/* LAYOUT */
.app{position:relative;z-index:1;display:grid;grid-template-columns:280px 1fr;min-height:calc(100vh - 58px)}

/* SIDEBAR */
.sidebar{border-right:1px solid rgba(255,255,255,0.06);padding:20px 16px;display:flex;flex-direction:column;gap:16px;background:#08080f}
.sidebar-section{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:#4d4a66;margin-bottom:8px}
.sidebar-input{width:100%;background:#111120;border:1px solid rgba(255,255,255,0.08);color:#edeaf7;font-family:'Outfit',sans-serif;font-size:13px;padding:9px 12px;border-radius:8px;outline:none;transition:border-color 0.2s}
.sidebar-input:focus{border-color:#7b6df4}
.sidebar-input::placeholder{color:#4d4a66}
select.sidebar-input{cursor:pointer}
.sector-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.sector-btn{padding:7px 8px;border-radius:7px;background:#111120;border:1px solid rgba(255,255,255,0.07);color:#8c89a6;font-family:'Outfit',sans-serif;font-size:11px;font-weight:500;cursor:pointer;transition:all 0.2s;text-align:center}
.sector-btn:hover{border-color:rgba(123,109,244,0.3);color:#a498ff}
.sector-btn.on{background:rgba(123,109,244,0.12);border-color:rgba(123,109,244,0.35);color:#a498ff;font-weight:700}
.mode-tabs{display:flex;background:#111120;border-radius:8px;padding:3px;gap:2px}
.mode-tab{flex:1;padding:7px;border-radius:6px;font-family:'Outfit',sans-serif;font-size:12px;font-weight:600;cursor:pointer;border:none;background:transparent;color:#4d4a66;transition:all 0.2s;text-align:center}
.mode-tab.on{background:#7b6df4;color:#fff}
.divider{height:1px;background:rgba(255,255,255,0.05)}

/* MAIN AREA */
.main{display:flex;flex-direction:column;height:calc(100vh - 58px)}
.chat-area{flex:1;overflow-y:auto;padding:24px;display:flex;flex-direction:column;gap:16px}
.chat-area::-webkit-scrollbar{width:4px}
.chat-area::-webkit-scrollbar-track{background:transparent}
.chat-area::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.08);border-radius:2px}

/* MESSAGES */
.msg{display:flex;flex-direction:column;gap:6px;max-width:820px}
.msg-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:#4d4a66}
.msg-bubble{padding:14px 18px;border-radius:12px;font-size:14px;line-height:1.7}
.msg-q .msg-bubble{background:#111120;border:1px solid rgba(255,255,255,0.07);color:#8c89a6;border-radius:12px 12px 12px 4px}
.msg-a .msg-bubble{background:rgba(123,109,244,0.08);border:1px solid rgba(123,109,244,0.18);color:#edeaf7;border-radius:4px 12px 12px 12px}
.msg-a .msg-bubble strong{color:#a498ff}
.msg-system .msg-bubble{background:rgba(200,168,75,0.07);border:1px solid rgba(200,168,75,0.15);color:#e6c668;font-size:13px;border-radius:10px}
.msg-error .msg-bubble{background:rgba(239,95,95,0.07);border:1px solid rgba(239,95,95,0.15);color:#ef5f5f;font-size:13px;border-radius:10px}

/* ANSWER META */
.answer-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-top:6px}
.meta-badge{padding:3px 10px;border-radius:10px;font-size:11px;font-weight:600}
.meta-time{background:rgba(69,222,122,0.08);color:#45de7a;border:1px solid rgba(69,222,122,0.15)}
.meta-copy{background:rgba(255,255,255,0.05);color:#8c89a6;border:1px solid rgba(255,255,255,0.08);cursor:pointer;transition:all 0.2s}
.meta-copy:hover{color:#edeaf7;border-color:rgba(255,255,255,0.16)}

/* THINKING */
.thinking{display:flex;align-items:center;gap:10px;padding:14px 18px;background:#111120;border:1px solid rgba(255,255,255,0.07);border-radius:12px;max-width:200px}
.think-dots{display:flex;gap:4px}
.think-dot{width:7px;height:7px;border-radius:50%;background:#7b6df4;animation:bounce 1.2s ease-in-out infinite}
.think-dot:nth-child(2){animation-delay:0.15s}
.think-dot:nth-child(3){animation-delay:0.3s}
@keyframes bounce{0%,80%,100%{transform:translateY(0);opacity:0.3}40%{transform:translateY(-6px);opacity:1}}
.think-label{font-size:12px;color:#4d4a66}

/* INPUT BAR */
.input-bar{padding:16px 20px;border-top:1px solid rgba(255,255,255,0.06);background:#08080f}
.input-row{display:flex;gap:10px;align-items:flex-end;max-width:900px}
.input-wrap{flex:1;position:relative}
#questionInput{width:100%;background:#111120;border:1px solid rgba(255,255,255,0.09);color:#edeaf7;font-family:'Outfit',sans-serif;font-size:14px;padding:12px 50px 12px 14px;border-radius:10px;outline:none;resize:none;min-height:48px;max-height:140px;line-height:1.5;transition:border-color 0.2s}
#questionInput:focus{border-color:#7b6df4}
#questionInput::placeholder{color:#4d4a66}
.mic-btn{position:absolute;right:10px;bottom:10px;width:30px;height:30px;border-radius:50%;border:none;background:rgba(123,109,244,0.15);color:#a498ff;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s;font-size:14px}
.mic-btn:hover{background:rgba(123,109,244,0.25)}
.mic-btn.listening{background:#ef5f5f;color:#fff;animation:pulse 0.8s ease-in-out infinite}
.send-btn{padding:12px 20px;background:#7b6df4;color:#fff;border:none;border-radius:10px;font-family:'Outfit',sans-serif;font-size:14px;font-weight:700;cursor:pointer;transition:all 0.2s;white-space:nowrap;height:48px}
.send-btn:hover{background:#9488ff;transform:translateY(-1px)}
.send-btn:disabled{opacity:0.5;cursor:not-allowed;transform:none}

/* EMPTY STATE */
.empty-state{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:40px;gap:16px}
.empty-icon{font-size:48px;opacity:0.4}
.empty-title{font-size:20px;font-weight:700;color:#edeaf7;letter-spacing:-0.3px}
.empty-sub{font-size:14px;color:#4d4a66;max-width:400px;line-height:1.7}
.starter-chips{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-top:8px}
.chip{padding:8px 14px;border-radius:20px;background:#111120;border:1px solid rgba(255,255,255,0.08);font-size:12px;color:#8c89a6;cursor:pointer;transition:all 0.2s;text-align:left}
.chip:hover{border-color:rgba(123,109,244,0.3);color:#a498ff;background:rgba(123,109,244,0.05)}

/* MOCK INTERVIEW */
.mock-header{padding:16px 20px;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;gap:12px;background:#08080f}
.mock-progress{flex:1;height:4px;background:rgba(255,255,255,0.06);border-radius:2px;overflow:hidden}
.mock-progress-bar{height:100%;background:#7b6df4;border-radius:2px;transition:width 0.4s ease}
.mock-q-count{font-size:12px;color:#4d4a66;white-space:nowrap}

/* DEBRIEF */
.debrief-card{background:#111120;border:1px solid rgba(255,255,255,0.08);border-radius:14px;padding:20px 24px;margin-bottom:12px}
.debrief-score{font-family:'Outfit',sans-serif;font-size:48px;font-weight:900;line-height:1}
.score-a{color:#45de7a}
.score-b{color:#e6c668}
.score-c{color:#f5a52a}

/* UPGRADE BANNER */
.upgrade-banner{margin:0 20px 16px;padding:14px 18px;background:rgba(200,168,75,0.07);border:1px solid rgba(200,168,75,0.18);border-radius:10px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
.upgrade-text{font-size:13px;color:#e6c668}
.upgrade-btn{padding:7px 16px;background:#e6c668;color:#07070e;border:none;border-radius:7px;font-family:'Outfit',sans-serif;font-size:12px;font-weight:700;cursor:pointer;text-decoration:none;white-space:nowrap}

/* RESPONSIVE */
@media(max-width:768px){
  .app{grid-template-columns:1fr}
  .sidebar{display:none}
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a class="nav-logo" href="/">PREPT AI</a>
  <div class="nav-badge"><div class="nav-badge-dot"></div> Live</div>
  <a href="/prept_match_v2.html" class="nav-btn nav-btn-ghost">Resume Match</a>
  <a href="/login.html" class="nav-btn nav-btn-gold">My Account</a>
</nav>

<div class="app">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <div>
      <div class="sidebar-section">Session Setup</div>
      <input class="sidebar-input" id="companyInput" placeholder="Company name (optional)" type="text"/>
    </div>
    <div>
      <input class="sidebar-input" id="roleInput" placeholder="Role / job title (optional)" type="text"/>
    </div>
    <div class="divider"></div>
    <div>
      <div class="sidebar-section">Mode</div>
      <div class="mode-tabs">
        <button class="mode-tab on" id="tabLive" onclick="setMode('live')">🎙 Live</button>
        <button class="mode-tab" id="tabMock" onclick="setMode('mock')">📋 Mock</button>
        <button class="mode-tab" id="tabDebrief" onclick="setMode('debrief')">📊 Debrief</button>
      </div>
    </div>
    <div class="divider"></div>
    <div>
      <div class="sidebar-section">Industry</div>
      <div class="sector-grid" id="sectorGrid"></div>
    </div>
    <div class="divider"></div>
    <div>
      <div class="sidebar-section">Answer Style</div>
      <select class="sidebar-input" id="styleSelect">
        <option value="star">STAR Method (behavioral)</option>
        <option value="concise">Concise & direct</option>
        <option value="story">Storytelling</option>
        <option value="technical">Technical & detailed</option>
        <option value="executive">Executive / senior level</option>
      </select>
    </div>
    <div style="margin-top:auto">
      <button onclick="clearChat()" style="width:100%;padding:8px;background:transparent;border:1px solid rgba(255,255,255,0.07);color:#4d4a66;border-radius:8px;font-family:'Outfit',sans-serif;font-size:12px;cursor:pointer;transition:all 0.2s" onmouseover="this.style.color='#8c89a6'" onmouseout="this.style.color='#4d4a66'">Clear session</button>
    </div>
  </div>

  <!-- MAIN -->
  <div class="main">
    <div class="chat-area" id="chatArea">
      <div class="empty-state" id="emptyState">
        <div class="empty-icon">🎙</div>
        <div class="empty-title">PREPT AI Live is ready.</div>
        <div class="empty-sub">Type or speak your interviewer's question and get a coached answer in seconds. Works alongside any video call.</div>
        <div class="starter-chips">
          <div class="chip" onclick="useStarter(this)">Tell me about yourself</div>
          <div class="chip" onclick="useStarter(this)">What's your greatest weakness?</div>
          <div class="chip" onclick="useStarter(this)">Why do you want to work here?</div>
          <div class="chip" onclick="useStarter(this)">Tell me about a challenge you overcame</div>
          <div class="chip" onclick="useStarter(this)">Where do you see yourself in 5 years?</div>
          <div class="chip" onclick="useStarter(this)">Why are you leaving your current job?</div>
        </div>
      </div>
    </div>

    <div id="upgradeBanner" style="display:none">
      <div class="upgrade-banner">
        <div class="upgrade-text">⚡ You've used your 3 free questions. Upgrade to Pro for unlimited coaching.</div>
        <a href="/#pricing" class="upgrade-btn">Upgrade to Pro →</a>
      </div>
    </div>

    <div class="input-bar">
      <div class="input-row">
        <div class="input-wrap">
          <textarea id="questionInput" placeholder="Type the interviewer's question here... or tap the mic to speak" rows="1" onkeydown="handleKey(event)" oninput="autoResize(this)"></textarea>
          <button class="mic-btn" id="micBtn" onclick="toggleMic()" title="Click to speak">🎤</button>
        </div>
        <button class="send-btn" id="sendBtn" onclick="sendQuestion()">Coach me →</button>
      </div>
    </div>
  </div>

</div>

<script>
const SECTORS = ['General','Technology','Healthcare','Legal','Finance','Sales','Retail','Logistics','Education','Hospitality','Customer Service','Skilled Trades','Admin/Office','Remote Work'];
let currentSector = 'General';
let currentMode = 'live';
let questionCount = 0;
const FREE_LIMIT = 3;
let mockQuestions = [];
let mockIndex = 0;
let sessionAnswers = [];

// Get user from session
const userRaw = sessionStorage.getItem('preptai_user');
const user = userRaw ? JSON.parse(userRaw) : null;
const userPlan = user?.plan || 'free';

// Build sector grid
const grid = document.getElementById('sectorGrid');
SECTORS.forEach(s => {
  const btn = document.createElement('button');
  btn.className = 'sector-btn' + (s === 'General' ? ' on' : '');
  btn.textContent = s;
  btn.onclick = () => {
    document.querySelectorAll('.sector-btn').forEach(b => b.classList.remove('on'));
    btn.classList.add('on');
    currentSector = s;
  };
  grid.appendChild(btn);
});

function setMode(mode) {
  currentMode = mode;
  ['live','mock','debrief'].forEach(m => {
    document.getElementById('tab' + m.charAt(0).toUpperCase() + m.slice(1)).classList.toggle('on', m === mode);
  });
  if (mode === 'mock') startMock();
  if (mode === 'debrief') showDebrief();
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 140) + 'px';
}

function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendQuestion(); }
}

function useStarter(el) {
  document.getElementById('questionInput').value = el.textContent;
  document.getElementById('emptyState')?.remove();
  sendQuestion();
}

function addMsg(type, labelText, content, meta = null) {
  const area = document.getElementById('chatArea');
  const empty = document.getElementById('emptyState');
  if (empty) empty.remove();

  const wrap = document.createElement('div');
  wrap.className = `msg msg-${type}`;

  const label = document.createElement('div');
  label.className = 'msg-label';
  label.textContent = labelText;

  const bubble = document.createElement('div');
  bubble.className = 'msg-bubble';
  bubble.innerHTML = content;

  wrap.appendChild(label);
  wrap.appendChild(bubble);

  if (meta) {
    const metaRow = document.createElement('div');
    metaRow.className = 'answer-meta';
    metaRow.innerHTML = meta;
    wrap.appendChild(metaRow);
  }

  area.appendChild(wrap);
  area.scrollTop = area.scrollHeight;
  return wrap;
}

function showThinking() {
  const area = document.getElementById('chatArea');
  const el = document.createElement('div');
  el.id = 'thinking';
  el.className = 'thinking';
  el.innerHTML = '<div class="think-dots"><div class="think-dot"></div><div class="think-dot"></div><div class="think-dot"></div></div><span class="think-label">Coaching your answer...</span>';
  area.appendChild(el);
  area.scrollTop = area.scrollHeight;
}

function removeThinking() {
  document.getElementById('thinking')?.remove();
}

async function sendQuestion() {
  const input = document.getElementById('questionInput');
  const q = input.value.trim();
  if (!q) return;

  if (userPlan === 'free' && questionCount >= FREE_LIMIT) {
    document.getElementById('upgradeBanner').style.display = 'block';
    return;
  }

  input.value = '';
  input.style.height = 'auto';
  document.getElementById('sendBtn').disabled = true;

  addMsg('q', '🎙 Interviewer asked', q);
  showThinking();

  const company = document.getElementById('companyInput').value.trim();
  const role = document.getElementById('roleInput').value.trim();
  const style = document.getElementById('styleSelect').value;

  const systemPrompt = `You are PREPT AI, an expert interview coach. The user is in a live job interview right now and needs a coached answer immediately.

Context:
- Industry/Sector: ${currentSector}
- Role: ${role || 'not specified'}
- Company: ${company || 'not specified'}
- Answer style: ${style}

Rules:
- Give a confident, natural-sounding answer the user can speak aloud
- Use the STAR method for behavioral questions (Situation, Task, Action, Result)
- Keep it conversational — not robotic or overly formal
- Length: 30-60 seconds when spoken aloud (roughly 80-130 words)
- After the answer, add a brief "💡 Delivery tip:" on a new line with one coaching note
- Do NOT say "Here is your answer" or any preamble — go straight into the answer`;

  try {
    const res = await fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-session-count': questionCount.toString() },
      body: JSON.stringify({
        message: `Interview question: "${q}"\n\nPlease provide a coached answer I can speak naturally.`,
        mode: 'chat',
        userEmail: user?.email || null,
        systemPrompt
      })
    });

    const data = await res.json();
    removeThinking();

    if (res.status === 403 && data.error === 'free_limit_reached') {
      document.getElementById('upgradeBanner').style.display = 'block';
      document.getElementById('sendBtn').disabled = false;
      return;
    }

    if (!res.ok) throw new Error(data.error || 'Something went wrong');

    const answer = data.answer || data.content?.[0]?.text || 'No response received.';
    const formatted = answer.replace(/\n/g, '<br>').replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');

    const wordCount = answer.split(' ').length;
    const speakTime = Math.round(wordCount / 130 * 60);
    const meta = `<span class="meta-badge meta-time">⏱ ~${speakTime}s to speak</span><span class="meta-badge meta-copy" onclick="copyAnswer(this, '${encodeURIComponent(answer)}')">📋 Copy</span>`;

    addMsg('a', '💬 Coached answer', formatted, meta);
    sessionAnswers.push({ question: q, answer });
    questionCount++;

    if (userPlan === 'free' && questionCount >= FREE_LIMIT) {
      document.getElementById('upgradeBanner').style.display = 'block';
    }

  } catch (err) {
    removeThinking();
    addMsg('error', '⚠️ Error', err.message || 'Something went wrong. Please try again.');
  }

  document.getElementById('sendBtn').disabled = false;
}

function copyAnswer(btn, encoded) {
  const text = decodeURIComponent(encoded);
  navigator.clipboard.writeText(text).then(() => {
    btn.textContent = '✓ Copied';
    setTimeout(() => btn.textContent = '📋 Copy', 2000);
  });
}

// Mock interview
const MOCK_QUESTIONS = [
  "Tell me about yourself and your background.",
  "What's your greatest professional strength?",
  "Describe a time you had to work under pressure to meet a deadline.",
  "Tell me about a conflict with a coworker and how you resolved it.",
  "Why are you interested in this role?",
  "Where do you see yourself in 3-5 years?",
  "What's your greatest weakness and what are you doing about it?",
  "Describe your most significant professional accomplishment."
];

function startMock() {
  mockIndex = 0;
  mockQuestions = [...MOCK_QUESTIONS].sort(() => Math.random() - 0.5).slice(0, 5);
  sessionAnswers = [];
  document.getElementById('chatArea').innerHTML = '';
  addMsg('system', '📋 Mock Interview', `Starting a ${mockQuestions.length}-question mock interview. Answer each question as naturally as you can. You will get a full debrief with scoring at the end.<br><br><strong>Question 1 of ${mockQuestions.length}:</strong><br>${mockQuestions[0]}`);
  document.getElementById('questionInput').placeholder = 'Type your answer to the mock question...';
}

function showDebrief() {
  if (sessionAnswers.length === 0) {
    addMsg('system', '📊 Debrief', 'Complete a mock interview or live session first — then come back here for your full performance breakdown.');
    return;
  }
  const score = Math.min(95, 65 + sessionAnswers.length * 6);
  const grade = score >= 85 ? 'A' : score >= 75 ? 'B' : 'C';
  const gradeClass = score >= 85 ? 'score-a' : score >= 75 ? 'score-b' : 'score-c';
  addMsg('system', '📊 Session Debrief', `
    <div style="display:flex;align-items:center;gap:16px;margin-bottom:16px">
      <div class="debrief-score ${gradeClass}">${score}</div>
      <div>
        <div style="font-size:18px;font-weight:700;color:#edeaf7">Grade ${grade} — ${score >= 85 ? 'Strong performance' : score >= 75 ? 'Good progress' : 'Keep practicing'}</div>
        <div style="font-size:13px;color:#8c89a6;margin-top:3px">${sessionAnswers.length} question${sessionAnswers.length !== 1 ? 's' : ''} answered this session</div>
      </div>
    </div>
    <div style="font-size:13px;color:#8c89a6;line-height:1.7">
      <strong style="color:#45de7a">✓ Strengths:</strong> You engaged with every question and provided structured responses.<br>
      <strong style="color:#e6c668">→ Focus area:</strong> Practice delivering answers without looking at the screen — aim to internalize the structure so it sounds fully natural.<br>
      <strong style="color:#a498ff">💡 Next step:</strong> Run another mock interview and try answering from memory before checking the coached response.
    </div>
  `);
}

// Mic / speech recognition
let recognition = null;
let isListening = false;

function toggleMic() {
  if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) {
    alert('Speech recognition is not supported in this browser. Please use Chrome or Edge, or type your question manually.');
    return;
  }
  if (isListening) {
    recognition?.stop();
    return;
  }
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  recognition = new SR();
  recognition.continuous = false;
  recognition.interimResults = true;
  recognition.lang = 'en-US';

  recognition.onstart = () => {
    isListening = true;
    document.getElementById('micBtn').classList.add('listening');
    document.getElementById('micBtn').textContent = '⏹';
    document.getElementById('questionInput').placeholder = 'Listening...';
  };

  recognition.onresult = (e) => {
    const transcript = Array.from(e.results).map(r => r[0].transcript).join('');
    document.getElementById('questionInput').value = transcript;
    autoResize(document.getElementById('questionInput'));
    if (e.results[e.results.length - 1].isFinal) {
      recognition.stop();
    }
  };

  recognition.onend = () => {
    isListening = false;
    document.getElementById('micBtn').classList.remove('listening');
    document.getElementById('micBtn').textContent = '🎤';
    document.getElementById('questionInput').placeholder = "Type the interviewer's question here... or tap the mic to speak";
    const val = document.getElementById('questionInput').value.trim();
    if (val) sendQuestion();
  };

  recognition.onerror = () => {
    isListening = false;
    document.getElementById('micBtn').classList.remove('listening');
    document.getElementById('micBtn').textContent = '🎤';
  };

  recognition.start();
}

function clearChat() {
  document.getElementById('chatArea').innerHTML = '<div class="empty-state" id="emptyState"><div class="empty-icon">🎙</div><div class="empty-title">Session cleared.</div><div class="empty-sub">Ready for your next question.</div></div>';
  questionCount = 0;
  sessionAnswers = [];
  document.getElementById('upgradeBanner').style.display = 'none';
}

// Welcome message
setTimeout(() => {
  if (user) {
    addMsg('system', '👋 Welcome back', `Signed in as <strong>${user.email}</strong> · Plan: <strong style="color:${userPlan === 'pro' || userPlan === 'career' ? '#45de7a' : '#e6c668'}">${userPlan.charAt(0).toUpperCase() + userPlan.slice(1)}</strong>${userPlan === 'free' ? ` · <span style="color:#f5a52a">${FREE_LIMIT - questionCount} free questions remaining</span>` : ' · Unlimited'}`);
  }
}, 300);
</script>
